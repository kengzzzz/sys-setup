LLAMA_ENV_FILE=.env.turboquant
HF_TOKEN=
BENCHMARK_BASELINE_IMAGE=ghcr.io/ggml-org/llama.cpp:full-cuda13
BENCHMARK_CANDIDATE_IMAGE=llama-server-turboquant
BENCHMARK_COMPOSE_FILE=docker-compose.experimental.yml
BENCHMARK_COMPOSE_SERVICE=llama-server
LLAMA_ARG_HF_REPO=unsloth/Qwen3.6-35B-A3B-GGUF:UD-Q4_K_XL
LLAMA_ARG_N_GPU_LAYERS=999
LLAMA_ARG_N_PARALLEL=1
LLAMA_ARG_FLASH_ATTN=on
LLAMA_ARG_CTX_SIZE=131072
LLAMA_ARG_CACHE_TYPE_K=q8_0
LLAMA_ARG_CACHE_TYPE_V=turbo4
LLAMA_ARG_N_CPU_MOE=21
LLAMA_ARG_MMAP=off
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=8080
TS_AUTHKEY=
TS_EXTRA_ARGS=
