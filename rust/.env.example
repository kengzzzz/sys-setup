# Copy to .env and point at the crate you are working on.
# Each project gets its own target volume via PROJECT_SLUG, so incremental
# builds survive across runs and projects do not invalidate each other.

PROJECT_DIR=
PROJECT_SLUG=hypr-kblayoutd
BIN_NAME=hypr-kblayoutd

# Host uid/gid, so files written into the bind mount stay yours.
LOCAL_UID=1000
LOCAL_GID=1000

ARCH_IMAGE_DIGEST=sha256:592e11bd99ab579f933a0cb77a8f66e2f3ae57f5eafacf13aea44a6e98ef21ae
